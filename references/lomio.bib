@article{lopez_challenges_2024,
	title = {Challenges of {COVID}-19 {Case} {Forecasting} in the {US}, 2020–2021},
	volume = {20},
	issn = {1553-7358},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1011200},
	doi = {10.1371/journal.pcbi.1011200},
	abstract = {During the COVID-19 pandemic, forecasting COVID-19 trends to support planning and response was a priority for scientists and decision makers alike. In the United States, COVID-19 forecasting was coordinated by a large group of universities, companies, and government entities led by the Centers for Disease Control and Prevention and the US COVID-19 Forecast Hub (https://covid19forecasthub.org). We evaluated approximately 9.7 million forecasts of weekly state-level COVID-19 cases for predictions 1–4 weeks into the future submitted by 24 teams from August 2020 to December 2021. We assessed coverage of central prediction intervals and weighted interval scores (WIS), adjusting for missing forecasts relative to a baseline forecast, and used a Gaussian generalized estimating equation (GEE) model to evaluate differences in skill across epidemic phases that were defined by the effective reproduction number. Overall, we found high variation in skill across individual models, with ensemble-based forecasts outperforming other approaches. Forecast skill relative to the baseline was generally higher for larger jurisdictions (e.g., states compared to counties). Over time, forecasts generally performed worst in periods of rapid changes in reported cases (either in increasing or decreasing epidemic phases) with 95\% prediction interval coverage dropping below 50\% during the growth phases of the winter 2020, Delta, and Omicron waves. Ideally, case forecasts could serve as a leading indicator of changes in transmission dynamics. However, while most COVID-19 case forecasts outperformed a naïve baseline model, even the most accurate case forecasts were unreliable in key phases. Further research could improve forecasts of leading indicators, like COVID-19 cases, by leveraging additional real-time data, addressing performance across phases, improving the characterization of forecast confidence, and ensuring that forecasts were coherent across spatial scales. In the meantime, it is critical for forecast users to appreciate current limitations and use a broad set of indicators to inform pandemic-related decision making.},
	language = {en},
	number = {5},
	urldate = {2026-03-04},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Lopez, Velma K. and Cramer, Estee Y. and Pagano, Robert and Drake, John M. and O’Dea, Eamon B. and Adee, Madeline and Ayer, Turgay and Chhatwal, Jagpreet and Dalgic, Ozden O. and Ladd, Mary A. and Linas, Benjamin P. and Mueller, Peter P. and Xiao, Jade and Bracher, Johannes and Castro Rivadeneira, Alvaro J. and Gerding, Aaron and Gneiting, Tilmann and Huang, Yuxin and Jayawardena, Dasuni and Kanji, Abdul H. and Le, Khoa and Mühlemann, Anja and Niemi, Jarad and Ray, Evan L. and Stark, Ariane and Wang, Yijin and Wattanachit, Nutcha and Zorn, Martha W. and Pei, Sen and Shaman, Jeffrey and Yamana, Teresa K. and Tarasewicz, Samuel R. and Wilson, Daniel J. and Baccam, Sid and Gurung, Heidi and Stage, Steve and Suchoski, Brad and Gao, Lei and Gu, Zhiling and Kim, Myungjin and Li, Xinyi and Wang, Guannan and Wang, Lily and Wang, Yueying and Yu, Shan and Gardner, Lauren and Jindal, Sonia and Marshall, Maximilian and Nixon, Kristen and Dent, Juan and Hill, Alison L. and Kaminsky, Joshua and Lee, Elizabeth C. and Lemaitre, Joseph C. and Lessler, Justin and Smith, Claire P. and Truelove, Shaun and Kinsey, Matt and Mullany, Luke C. and Rainwater-Lovett, Kaitlin and Shin, Lauren and Tallaksen, Katharine and Wilson, Shelby and Karlen, Dean and Castro, Lauren and Fairchild, Geoffrey and Michaud, Isaac and Osthus, Dave and Bian, Jiang and Cao, Wei and Gao, Zhifeng and Ferres, Juan Lavista and Li, Chaozhuo and Liu, Tie-Yan and Xie, Xing and Zhang, Shun and Zheng, Shun and Chinazzi, Matteo and Davis, Jessica T. and Mu, Kunpeng and Piontti, Ana Pastore y and Vespignani, Alessandro and Xiong, Xinyue and Walraven, Robert and Chen, Jinghui and Gu, Quanquan and Wang, Lingxiao and Xu, Pan and Zhang, Weitong and Zou, Difan and Gibson, Graham Casey and Sheldon, Daniel and Srivastava, Ajitesh and Adiga, Aniruddha and Hurt, Benjamin and Kaur, Gursharn and Lewis, Bryan and Marathe, Madhav and Peddireddy, Akhil Sai and Porebski, Przemyslaw and Venkatramanan, Srinivasan and Wang, Lijing and Prasad, Pragati V. and Walker, Jo W. and Webber, Alexander E. and Slayton, Rachel B. and Biggerstaff, Matthew and Reich, Nicholas G. and Johansson, Michael A.},
	month = may,
	year = {2024},
	keywords = {United States, Infectious diseases, Public and occupational health, Forecasting, Pandemics, Geography, Research reporting guidelines, COVID 19},
	pages = {e1011200},
	file = {Full Text PDF:/Users/ajcr./Library/CloudStorage/OneDrive-UniversityofMassachusetts/micokoch/Zotero/storage/FCEDAJNH/Lopez et al. - 2024 - Challenges of COVID-19 Case Forecasting in the US, 2020–2021.pdf:application/pdf},
