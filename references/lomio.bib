@article{cramer_united_2022,
	title = {The {United} {States} {COVID}-19 {Forecast} {Hub} dataset},
	volume = {9},
	copyright = {2022 The Author(s)},
	issn = {2052-4463},
	url = {https://www.nature.com/articles/s41597-022-01517-w},
	doi = {10.1038/s41597-022-01517-w},
	abstract = {Academic researchers, government agencies, industry groups, and individuals have produced forecasts at an unprecedented scale during the COVID-19 pandemic. To leverage these forecasts, the United States Centers for Disease Control and Prevention (CDC) partnered with an academic research lab at the University of Massachusetts Amherst to create the US COVID-19 Forecast Hub. Launched in April 2020, the Forecast Hub is a dataset with point and probabilistic forecasts of incident cases, incident hospitalizations, incident deaths, and cumulative deaths due to COVID-19 at county, state, and national, levels in the United States. Included forecasts represent a variety of modeling approaches, data sources, and assumptions regarding the spread of COVID-19. The goal of this dataset is to establish a standardized and comparable set of short-term forecasts from modeling teams. These data can be used to develop ensemble models, communicate forecasts to the public, create visualizations, compare models, and inform policies regarding COVID-19 mitigation. These open-source data are available via download from GitHub, through an online API, and through R packages.},
	language = {en},
	number = {1},
	urldate = {2026-03-04},
	journal = {Scientific Data},
	publisher = {Nature Publishing Group},
	author = {Cramer, Estee Y. and Huang, Yuxin and Wang, Yijin and Ray, Evan L. and Cornell, Matthew and Bracher, Johannes and Brennen, Andrea and Castro Rivadeneira, Alvaro J. and Gerding, Aaron and House, Katie and Jayawardena, Dasuni and Kanji, Abdul Hannan and Khandelwal, Ayush and Le, Khoa and Mody, Vidhi and Mody, Vrushti and Niemi, Jarad and Stark, Ariane and Shah, Apurv and Wattanchit, Nutcha and Zorn, Martha W. and Reich, Nicholas G.},
	month = aug,
	year = {2022},
	keywords = {Viral infection, Software, Computer science, Databases, Scientific data},
	pages = {462},
	file = {Full Text PDF:/Users/ajcr./Library/CloudStorage/OneDrive-UniversityofMassachusetts/micokoch/Zotero/storage/AJW4LRC3/Cramer et al. - 2022 - The United States COVID-19 Forecast Hub dataset.pdf:application/pdf},
}

@article{shandross_multi-model_2026,
	title = {Multi-{Model} {Ensembles} in {Infectious} {Disease} and {Public} {Health}: {Methods}, {Interpretation}, and {Implementation} in {R}},
	volume = {45},
	issn = {1097-0258},
	shorttitle = {Multi-{Model} {Ensembles} in {Infectious} {Disease} and {Public} {Health}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/sim.70333},
	doi = {10.1002/sim.70333},
	abstract = {Combining predictions from multiple models into an ensemble is a widely used practice across many fields with demonstrated performance benefits. Popularized through domains such as weather forecasting and climate modeling, multi-model ensembles are becoming increasingly common in public health and biological applications. For example, multi-model outbreak forecasting provides more accurate and reliable information about the timing and burden of infectious disease outbreaks to public health officials and medical practitioners. Yet, understanding and interpreting multi-model ensemble results can be difficult, as there are a diversity of methods proposed in the literature with no clear consensus on which is best. Moreover, a lack of standard, easy-to-use software implementations impedes the generation of multi-model ensembles in practice. To address these challenges, we provide an introduction to the statistical foundations of applied probabilistic forecasting, including the role of multi-model ensembles. We introduce the hubEnsembles package, a flexible framework for ensembling various types of predictions using a range of methods. Finally, we present a tutorial and case-study of ensemble methods using the hubEnsembles package on a subset of real, publicly available data from the FluSight Forecast Hub.},
	language = {en},
	number = {1-2},
	urldate = {2026-03-04},
	journal = {Statistics in Medicine},
	author = {Shandross, Li and Howerton, Emily and Contamin, Lucie and Hochheiser, Harry and Krystalli, Anna and {Consortium of Infectious Disease Modeling Hubs} and Reich, Nicholas G. and Ray, Evan L.},
	year = {2026},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/sim.70333},
	keywords = {forecast, prediction, aggregation, multiple models},
	pages = {e70333},
	file = {Full Text PDF:/Users/ajcr./Library/CloudStorage/OneDrive-UniversityofMassachusetts/micokoch/Zotero/storage/4N7N3MS5/Shandross et al. - 2026 - Multi-Model Ensembles in Infectious Disease and Public Health Methods, Interpretation, and Implemen.pdf:application/pdf;Snapshot:/Users/ajcr./Library/CloudStorage/OneDrive-UniversityofMassachusetts/micokoch/Zotero/storage/649HKCFR/sim.html:text/html},
}

